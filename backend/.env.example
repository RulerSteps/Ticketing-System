# Copier ce fichier en .env et renseigner les valeurs

# Serveur
# Le frontend (frontend/.env.example -> VITE_API_URL) pointe par defaut sur le port 5000.
PORT=5000
NODE_ENV=development

# Base de donnees MySQL / MariaDB (XAMPP / WAMP / Laragon en local)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ticketing_it
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=8h

# Frontend (pour CORS)
FRONTEND_URL=http://localhost:3000
